    "IncidentReport": {
      "title": "IncidentReport",
      "description": "Incidents logged during production",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productionId": { "type": "string" },
        "description": { "type": "string" },
        "remark": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["id", "productionId", "description", "remark"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Buyer of finished goods",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "contactPerson": { "type": "string" }
      },
      "required": ["id", "name", "phone"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Vendor of raw materials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "contactPerson": { "type": "string" }
      },
      "required": ["id", "name", "phone"]
    },
    "Tax": {
      "title": "Tax",
      "description": "Tax definitions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rate": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "rate"]
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "Purchase order issued to a supplier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "orderDate": { "type": "string" },
        "expectedDeliveryDate": { "type": "string" },
        "receivedDate": { "type": "string" },
        "taxRate": { "type": "number" },
        "taxAmount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "supplierId", "orderDate", "expectedDeliveryDate", "totalAmount", "status"]
    },
    "SalesOrder": {
      "title": "SalesOrder",
      "description": "Sales order from a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "orderDate": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "receivedDate": { "type": "string" },
        "taxRate": { "type": "number" },
        "taxAmount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "customerId", "productId", "quantity", "unitPrice", "orderDate", "deliveryDate", "totalAmount", "status"]
