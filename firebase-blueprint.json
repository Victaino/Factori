    "Expense": {
      "title": "Expense",
      "description": "Operating expense recording",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "taxRate": { "type": "number" },
        "taxAmount": { "type": "number" },
        "amount": { "type": "number" },
        "paid": { "type": "number" },
        "balance": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["id", "supplierId", "items", "quantity", "price", "amount", "paid", "balance", "date"]
