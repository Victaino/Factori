    "Employee": {
      "title": "Employee",
      "description": "HR Employee profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "string" },
        "photo": { "type": "string" },
