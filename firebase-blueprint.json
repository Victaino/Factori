{
  "entities": {
    "Plant": {
      "title": "Plant",
      "description": "A production plant facility",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Operator": {
      "title": "Operator",
      "description": "A machine or station operator",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Material": {
      "title": "Material",
      "description": "Raw materials inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "amount": { "type": "number" },
        "trackInventory": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "quantity", "amount"]
    },
    "Product": {
      "title": "Product",
      "description": "Finished product definition",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "amount": { "type": "number" },
        "imageUrl": { "type": "string" },
        "trackInventory": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "quantity", "amount"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Inventory storage tracking records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "lowStockThreshold": { "type": "number" }
      },
      "required": ["id", "productId", "quantity", "price"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Fixed asset registry item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "item": { "type": "string" },
        "make": { "type": "string" },
        "type": { "type": "string" },
        "serialNumber": { "type": "string" },
        "color": { "type": "string" },
        "qty": { "type": "number" },
        "unitPrice": { "type": "number" },
        "total": { "type": "number" },
        "remark": { "type": "string" }
      },
      "required": ["id", "item", "qty", "unitPrice", "total"]
