    "Sale": {
      "title": "Sale",
      "description": "Sales invoice transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "taxRate": { "type": "number" },
        "taxAmount": { "type": "number" },
        "amount": { "type": "number" },
        "paid": { "type": "number" },
        "balance": { "type": "number" },
        "date": { "type": "string" }
