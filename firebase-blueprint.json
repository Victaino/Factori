    "Production": {
      "title": "Production",
      "description": "Production log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "productId": { "type": "string" },
        "plantId": { "type": "string" },
        "operatorId": { "type": "string" },
        "materialsUsed": { "type": "array" },
        "outputTonnage": { "type": "number" },
        "outputUnit": { "type": "string" },
        "timeStart": { "type": "string" },
        "timeStop": { "type": "string" },
        "duration": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "date", "productId", "plantId", "operatorId", "materialsUsed", "outputTonnage", "timeStart", "timeStop", "duration"]
